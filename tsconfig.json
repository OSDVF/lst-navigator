{
    // https://nuxt.com/docs/guide/concepts/typescript
    "extends": "./.nuxt/tsconfig.json",
    "compilerOptions": {
        "lib": [
            "ESNext",
            "DOM",
            "WebWorker",
        ],
        "types": [
            "./global.d.ts",
            "@types/google.picker",
            "@types/gapi.auth2",
            "@types/gapi.client.drive-v3",
            "@types/gapi.client.forms-v1",
            "datatables.net-buttons-dt",
            "datatables.net-colreorder-dt",
